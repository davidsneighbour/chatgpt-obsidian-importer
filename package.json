{
  "name": "chatgpt-obsidian-importer",
  "version": "0.1.0",
  "private": true,
  "description": "Import ChatGPT data exports into an Obsidian vault as structured Markdown notes.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.11.1",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "chatgpt:analyse": "tsx src/scripts/analyse-export.ts",
    "chatgpt:diff": "tsx src/scripts/diff-export.ts",
    "chatgpt:precheck": "tsx src/scripts/pre-import-check.ts",
    "clean": "rimraf dist",
    "dev:import": "tsx src/scripts/import-chatgpt-export.ts",
    "dev:import-latest": "tsx src/scripts/import-latest-chatgpt-export.ts",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "release": "release-it --config .release-it.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^25.5.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
